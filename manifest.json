{
  "manifest_version": 3,
  "name": "Concept Video Finder",
  "version": "1.0.0",
  "description": "Highlight educational or financial concepts to instantly find the best YouTube video resources with Gemini 2.0 Flash.",
  "permissions": [
    "contextMenus",
    "sidePanel",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
